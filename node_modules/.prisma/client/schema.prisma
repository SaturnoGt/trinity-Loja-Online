datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_8CrUXjyZa7xJ@ep-empty-bonus-ath4lqpj.c-9.us-east-1.aws.neon.tech:5432/neondb?sslmode=require"
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  description String?
  category    String?
  createdAt   DateTime @default(now())

  images     Image[]
  variations Variation[]
  orderItems OrderItem[]
}

model Image {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  isMain    Boolean @default(false)
  productId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Variation {
  id    Int    @id @default(autoincrement())
  size  String
  color String
  stock Int

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       String   @default("CLIENTE")
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders Order[]
}

model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(PENDING)
  total     Float
  paymentId String?     @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(uuid())

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  productName String

  quantity  Int
  unitPrice Float

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
